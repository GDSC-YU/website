---
import LogoModel from "./LogoModel.svelte";
---

<section id="landing">
  <div
    class="mx-auto flex flex-col items-center justify-between gap-y-16 px-8 py-14 md:flex-row lg:px-10 lg:py-20"
  >
    <div
      class="flex flex-col items-center gap-y-9 text-center text-white md:w-1/2 md:items-start md:gap-y-6 md:text-left lg:flex-grow"
    >
      <a
        href="https://yu.edu.sa/campus/student-clubs/"
        target="_blank"
        rel="noreferrer"
        class="text-lg font-bold text-orange-400 underline-offset-8 hover:underline lg:text-3xl"
        >Al-Yamamah University</a
      >
      <h1 class="text-3xl font-bold lg:text-6xl">
        Google Developers <br /> Student Club
      </h1>
      <p class="text-lg font-bold lg:text-3xl">Learn, Grow, and Connect!</p>
      <div class="flex justify-center">
        <button class="rounded bg-orange-400 py-2 px-12 hover:scale-105">
          <a
            href="https://gdsc.community.dev/"
            target="_blank"
            rel="noreferrer"
            class="text-lg font-bold">Learn More</a
          >
        </button>
      </div>
    </div>
    <LogoModel client:only="svelte" />
  </div>
</section>
